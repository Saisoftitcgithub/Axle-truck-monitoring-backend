# Truck Monitoring Backend — copy to .env and set as needed
# Database: PostgreSQL (production) or leave unset for SQLite (local)

# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Example (local PostgreSQL):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/truck_movements
# Example (Docker Compose postgres — port 5433):
# DATABASE_URL=postgresql://truck_user:truck_password_123@localhost:5433/truck_movements

# Axle detection (optional — used by axle_runner after entry)
# AXLE_MODEL_SCRIPT=C:\path\to\process_video_tracking.py
# MODEL_PATH=C:\path\to\best.pt
# AXLE_VIDEO_PATH=C:\path\to\video.mp4

# Internal API base for axle_runner (default: http://127.0.0.1:8000)
# TRUCK_API_BASE=http://127.0.0.1:8000
